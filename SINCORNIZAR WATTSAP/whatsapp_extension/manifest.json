{
  "manifest_version": 3,
  "name": "WhatsApp Classifier Integration",
  "version": "1.1",
  "description": "Clasifica direcciones y mensajes directamente desde WhatsApp Web.",
  "permissions": [],
  "host_permissions": [
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
